---
import Layout from "../../layouts/Layout.astro";
import "../../styles/star-gradient.css";
import "../../styles/project-page.css";
import presentation from "../../assets/others/braille-snake/braille-snake.png";
import demo from "../../assets/others/braille-snake/demo.gif";
import tmux from "../../assets/others/braille-snake/tmux.gif";
import help from "../../assets/others/braille-snake/help.png";

import type en from "../../i18n/braille-snake.en";
type Strings = typeof en;

export interface Props {
  strings: Strings;
  lang?: string;
}

const { strings: s, lang } = Astro.props;

const GITHUB = "https://github.com/Pierre-Mollard/braille-snake";

// A feature entry is either a plain string, or a tuple where
// even indexes are plain text and odd indexes are <code> segments.
type FeatureEntry = string | readonly string[];
---

<Layout title="braille-snake" lang={lang}>
  <canvas id="starfield"></canvas>

  <main class="relative z-10 w-full max-w-3xl mx-auto px-4 sm:px-6 pt-20 pb-16 font-mono text-slate-200">

    <!-- ─── HERO ─────────────────────────────────────────────── -->
    <section class="text-center pb-12 mb-12 border-b border-white/[0.08]">
      <div class="flex flex-wrap gap-2 justify-center mb-6">
        {["C", "cmake", "terminal", "tmux", "ASCII"].map(t => (
          <span class="tag">{t}</span>
        ))}
      </div>

      <h1 class="text-4xl sm:text-6xl font-bold tracking-tight leading-tight mb-4 text-slate-50">
        braille<span class="text-green-300">-snake</span>
      </h1>

      <p class="text-base sm:text-lg leading-relaxed text-slate-400 max-w-prose mx-auto mb-8 font-sans">
        {s.subtitle}
      </p>

      <div class="flex flex-wrap gap-3 justify-center">
        <a href={GITHUB} target="_blank" rel="noopener noreferrer"
           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-semibold bg-green-300 text-slate-900 hover:bg-green-200 transition-colors">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755-1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.605-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          {s.viewOnGithub}
        </a>
        <a href="#demo"
           class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-semibold border border-white/20 text-slate-300 hover:border-white/40 hover:text-slate-100 transition-colors">
          {s.seeDemo}
        </a>
      </div>
    </section>

    <!-- ─── MEDIA SECTIONS ───────────────────────────────────── -->
    <section class="mb-14" id="demo">
      <h2 class="section-title"><span class="text-green-300">$</span> {s.sections.screenshot}</h2>
      <div class="rounded-xl overflow-hidden border border-white/10 bg-[#0d1117]">
        <img src={presentation.src} alt="braille-snake running in a terminal" loading="lazy" class="w-full h-auto block" />
        <p class="px-4 py-2 text-xs text-slate-600 border-t border-white/[0.06] font-sans">{s.captions.screenshot}</p>
      </div>
    </section>

    <section class="mb-14">
      <h2 class="section-title"><span class="text-green-300">$</span> {s.sections.demo}</h2>
      <div class="rounded-xl overflow-hidden border border-white/10 bg-[#0d1117]">
        <img src={demo.src} alt="braille-snake gameplay demo" loading="lazy" class="w-full h-auto block" />
        <p class="px-4 py-2 text-xs text-slate-600 border-t border-white/[0.06] font-sans">
          {s.captions.demo.split("asciinema").map((part, i) =>
            i === 0 ? part : <><code class="text-green-300">asciinema</code>{part}</>
          )}
        </p>
      </div>
    </section>

    <section class="mb-14">
      <h2 class="section-title"><span class="text-green-300">$</span> {s.sections.demoTmux}</h2>
      <div class="rounded-xl overflow-hidden border border-white/10 bg-[#0d1117]">
        <img src={tmux.src} alt="braille-snake demo inside tmux status bar" loading="lazy" class="w-full h-auto block" />
        <p class="px-4 py-2 text-xs text-slate-600 border-t border-white/[0.06] font-sans">
          {s.captions.demoTmux.split("ShareX").map((part, i) =>
            i === 0 ? part : <><code class="text-green-300">ShareX</code>{part}</>
          )}
        </p>
      </div>
    </section>

    <section class="mb-14">
      <h2 class="section-title"><span class="text-green-300">$</span> {s.sections.configurable}</h2>
      <div class="rounded-xl overflow-hidden border border-white/10 bg-[#0d1117]">
        <img src={help.src} alt="braille-snake help function" loading="lazy" class="w-full h-auto block" />
        <p class="px-4 py-2 text-xs text-slate-600 border-t border-white/[0.06] font-sans">{s.captions.configurable}</p>
      </div>
    </section>

    <!-- ─── FEATURES ──────────────────────────────────────────── -->
    <section class="mb-14">
      <h2 class="section-title"><span class="text-green-300">$</span> {s.sections.features}</h2>
      <ul class="flex flex-col gap-3 font-sans text-slate-300 text-sm sm:text-base leading-relaxed">
        {(s.features as readonly FeatureEntry[]).map((feature) => (
          <li class="flex gap-3">
            <span class="text-green-300 shrink-0">▸</span>
            <span>
              {Array.isArray(feature)
                ? (feature as readonly string[]).map((chunk, i) =>
                    i % 2 === 0
                      ? chunk
                      : <code class="inline-code">{chunk}</code>
                  )
                : feature}
            </span>
          </li>
        ))}
      </ul>
    </section>

    <!-- ─── BUILD & RUN ───────────────────────────────────────── -->
    <section class="mb-14">
      <h2 class="section-title"><span class="text-green-300">$</span> {s.sections.buildRun}</h2>
      <div class="rounded-xl overflow-hidden border border-white/10 bg-[#090d13]">
        <div class="flex items-center gap-1.5 px-4 py-2.5 bg-[#161b22] border-b border-white/[0.07]">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="mx-auto text-xs text-slate-600">bash</span>
        </div>
        <pre class="overflow-x-auto p-4 sm:p-5 text-xs sm:text-sm leading-relaxed m-0"><code
><span class="text-slate-600">{s.buildComments.clone}</span>
<span class="text-green-300">git clone</span> {GITHUB}
<span class="text-green-300">cd</span> braille-snake

<span class="text-slate-600">{s.buildComments.build}</span>
<span class="text-green-300">cmake --build build</span>

<span class="text-slate-600">{s.buildComments.install}</span>
<span class="text-green-300">cmake --install build --prefix ~/.local</span>

<span class="text-slate-600">{s.buildComments.run}</span>
<span class="text-green-300">./braille-snake</span></code></pre>
      </div>
    </section>

    <!-- ─── TMUX TIP ───────────────────────────────────────────── -->
    <section class="mb-14">
      <h2 class="section-title"><span class="text-green-300">$</span> {s.sections.tmuxBar}</h2>
      <div class="rounded-xl overflow-hidden border border-white/10 bg-[#090d13]">
        <div class="flex items-center gap-1.5 px-4 py-2.5 bg-[#161b22] border-b border-white/[0.07]">
          <span class="w-3 h-3 rounded-full bg-[#ff5f57]"></span>
          <span class="w-3 h-3 rounded-full bg-[#febc2e]"></span>
          <span class="w-3 h-3 rounded-full bg-[#28c840]"></span>
          <span class="mx-auto text-xs text-slate-600">tmux</span>
        </div>
        <pre class="overflow-x-auto p-4 sm:p-5 text-xs sm:text-sm leading-relaxed m-0"><code
><span class="text-slate-600">{s.tmuxComment}</span></code></pre>
      </div>
    </section>

    <!-- ─── TECH STACK ────────────────────────────────────────── -->
    <section class="mb-14">
      <h2 class="section-title"><span class="text-green-300">$</span> {s.sections.stack}</h2>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        {s.stack.map(({ icon, name, desc }) => (
          <div class="flex flex-col gap-1 p-4 rounded-lg border border-white/[0.08] bg-white/[0.03] hover:border-green-300/30 hover:bg-green-300/[0.05] transition-colors">
            <span class="text-xl">{icon}</span>
            <span class="text-sm font-semibold text-slate-100">{name}</span>
            <span class="text-xs text-slate-500 font-sans">{desc}</span>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── CTA ────────────────────────────────────────────────── -->
    <section class="flex flex-col items-center gap-4 pt-10 mt-6 border-t border-white/[0.08] text-center">
      <p class="text-slate-400 font-sans text-base">{s.ctaText}</p>
      <a href={GITHUB} target="_blank" rel="noopener noreferrer"
         class="inline-flex items-center gap-2 px-5 py-2.5 rounded-md text-sm font-semibold bg-green-300 text-slate-900 hover:bg-green-200 transition-colors">
        {s.openOnGithub}
      </a>
    </section>

  </main>
</Layout>

<style>
  .tag {
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.2rem 0.65rem;
    border: 1px solid rgba(134, 239, 172, 0.35);
    border-radius: 9999px;
    color: #86efac;
    background: rgba(134, 239, 172, 0.07);
  }

  .section-title {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 1rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .inline-code {
    font-family: 'JetBrains Mono', 'Fira Mono', monospace;
    font-size: 0.85em;
    color: #86efac;
    background: rgba(134, 239, 172, 0.1);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  pre { -webkit-overflow-scrolling: touch; }
</style>
