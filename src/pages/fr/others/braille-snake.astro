---
import Layout from "../../../layouts/Layout.astro";
import "../../../styles/star-gradient.css";
---

<Layout title="braille-snake" lang="fr">
  <div id="stars"></div>
  <div id="stars2"></div>
  <div id="stars3"></div>

  <main class="page">

    <!-- ─── HERO ─────────────────────────────────────────────── -->
    <section class="hero">
      <div class="hero-meta">
        <span class="tag">C</span>
        <span class="tag">cmake</span>
        <span class="tag">terminal</span>
        <span class="tag">tmux</span>
        <span class="tag">ASCII</span>
      </div>

      <h1 class="title">
        braille<span class="accent">-snake</span>
      </h1>

      <p class="subtitle">
        Un jeu Snake rendu entièrement en caractères Braille Unicode, jouable dans n'importe 
        quel terminal et optimisé pour la barre de statut tmux.
      </p>

      <div class="hero-actions">
        <a
          class="btn btn-primary"
          href="https://github.com/Pierre-Mollard/braille-snake"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577
              0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61-.546-1.385-1.335-1.755
              -1.335-1.755-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236
              1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466
              -1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176
              0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405
              2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23
              1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22
              0 1.605-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 21.795 24 17.295
              24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          Voir sur GitHub
        </a>

        <a class="btn btn-ghost" href="#demo">
          Voir demo ↓
        </a>
      </div>
    </section>

    <!-- ─── SCREENSHOT ────────────────────────────────────────── -->
    <section class="section" id="demo">
      <h2 class="section-title"><span class="prompt">$</span> Capture d'écran</h2>

      <div class="media-frame">
        <img
          src="/src/assets/others/braille-snake/braille-snake.png"
          alt="braille-snake exécuté dans un terminal"
          width="900"
          height="500"
          loading="lazy"
          class="media-img placeholder-img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="media-caption">braille-snake — plein écran</div>
      </div>
    </section>

    <!-- ─── GIF / DEMO ────────────────────────────────────────── -->
    <section class="section">
      <h2 class="section-title"><span class="prompt">$</span> Demo</h2>

      <div class="media-frame">
        <img
          src="/src/assets/others/braille-snake/demo.gif"
          alt="braille-snake gameplay demo"
          width="900"
          height="500"
          loading="lazy"
          class="media-img placeholder-img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="media-caption">Enregistré avec <code>asciinema</code> + converti en GIF</div>
      </div>
    </section>
    
    <!-- ─── GIF / DEMO TMUX ────────────────────────────────────────── -->
    <section class="section">
      <h2 class="section-title"><span class="prompt">$</span> Demo Dans Tmux</h2>

      <div class="media-frame">
        <img
          src="/src/assets/others/braille-snake/tmux.gif"
          alt="braille-snake gameplay demo dans la status bar tmux"
          width="900"
          height="500"
          loading="lazy"
          class="media-img placeholder-img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="media-caption">Enregistré avec <code>ShareX</code> + converti en GIF</div>
      </div>
    </section>
    
    <!-- ─── SCREENSHOT HELP ────────────────────────────────────────── -->
    <section class="section" id="demo">
      <h2 class="section-title"><span class="prompt">$</span> Configurable</h2>

      <div class="media-frame">
        <img
          src="/src/assets/others/braille-snake/help.png"
          alt="braille-snake fonction d'utilisation dans le terminal"
          width="900"
          height="500"
          loading="lazy"
          class="media-img placeholder-img"
          onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
        />
        <div class="media-caption">braille-snake — fonction d'utilisation</div>
      </div>
    </section>

    <!-- ─── FEATURES ──────────────────────────────────────────── -->
    <section class="section">
      <h2 class="section-title"><span class="prompt">$</span> Features</h2>

      <ul class="feature-list">
        <li><span class="bullet">▸</span> Rendu entièrement avec les caractères Braille Unicode (U+2800–U+28FF)</li>
        <li><span class="bullet">▸</span> Gestion fluide des entrées avec <code>aucune dépendance externe</code></li>
        <li><span class="bullet">▸</span> Compatible avec n'importe quel terminal POSIX</li>
        <li><span class="bullet">▸</span> Compatible avec tmux via un serveur <code>unix socket</code></li>
        <li><span class="bullet">▸</span> Taille du jeu, vitesse et autres paramètres configurables</li>
      </ul>
    </section>

    <!-- ─── BUILD & RUN ───────────────────────────────────────── -->
    <section class="section">
      <h2 class="section-title"><span class="prompt">$</span> Build &amp; run</h2>

      <div class="terminal-block">
        <div class="terminal-bar">
          <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
          <span class="terminal-title">bash</span>
        </div>
        <pre class="terminal-body"><code
><span class="c-comment"># Clone du depot</span>
<span class="c-cmd">git clone</span> https://github.com/Pierre-Mollard/braille-snake
<span class="c-cmd">cd</span> braille-snake

<span class="c-comment"># Compilation programme</span>
<span class="c-cmd">cmake --build build</span>
          
<span class="c-comment"># Installation programme</span>
<span class="c-cmd">cmake --install build --prefix ~/.local</span>

<span class="c-comment"># Exécution</span>
<span class="c-cmd">./braille-snake</span></code></pre>
      </div>
    </section>

    <!-- ─── TMUX TIP ───────────────────────────────────────────── -->
    <section class="section">
      <h2 class="section-title"><span class="prompt">$</span> Exécution dans tmux status bar</h2>

      <div class="terminal-block">
        <div class="terminal-bar">
          <span class="dot red"></span><span class="dot yellow"></span><span class="dot green"></span>
          <span class="terminal-title">tmux</span>
        </div>
        <pre class="terminal-body"><code
><span class="c-comment"># Copier le fichier config dans votre configuration tmux (voir README.md)</span>
      </div>
    </section>

    <!-- ─── TECH STACK ────────────────────────────────────────── -->
    <section class="section">
      <h2 class="section-title"><span class="prompt">$</span> Stack</h2>

      <div class="stack-grid">
        <div class="stack-card">
          <span class="stack-icon">⚙</span>
          <span class="stack-name">C99</span>
          <span class="stack-desc">Langage</span>
        </div>
        <div class="stack-card">
          <span class="stack-icon">🖥</span>
          <span class="stack-name">Terminal</span>
          <span class="stack-desc">Custom TUI rendering</span>
        </div>
        <div class="stack-card">
          <span class="stack-icon">⬛</span>
          <span class="stack-name">TMUX</span>
          <span class="stack-desc">Terminal Multiplexer cible</span>
        </div>
        <div class="stack-card">
          <span class="stack-icon">⚙</span>
          <span class="stack-name">cmake</span>
          <span class="stack-desc">Chaine de compilation</span>
        </div>
      </div>
    </section>

    <!-- ─── CTA ────────────────────────────────────────────────── -->
    <section class="cta-section">
      <p class="cta-text">Envie d'essayer ou de contribuer ?</p>
      <a
        class="btn btn-primary"
        href="https://github.com/Pierre-Mollard/braille-snake"
        target="_blank"
        rel="noopener noreferrer"
      >
        Ouvrir sur GitHub →
      </a>
    </section>

  </main>
</Layout>

<style>
  /* ── Layout ─────────────────────────────────── */
  .page {
    position: relative;
    z-index: 1;
    max-width: 860px;
    margin: 0 auto;
    padding: 6rem 1.5rem 4rem;
    font-family: 'JetBrains Mono', 'Fira Mono', monospace;
    color: #e2e8f0;
  }

  /* ── Hero ───────────────────────────────────── */
  .hero {
    text-align: center;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
    margin-bottom: 4rem;
  }

  .hero-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    justify-content: center;
    margin-bottom: 1.5rem;
  }

  .tag {
    font-size: 0.72rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 0.25rem 0.75rem;
    border: 1px solid rgba(134, 239, 172, 0.35);
    border-radius: 9999px;
    color: #86efac;
    background: rgba(134, 239, 172, 0.07);
  }

  .title {
    font-size: clamp(2.4rem, 7vw, 4.5rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin-bottom: 1.25rem;
    color: #f8fafc;
  }

  .accent {
    color: #86efac;
  }

  .subtitle {
    font-size: 1.05rem;
    line-height: 1.7;
    color: #94a3b8;
    max-width: 56ch;
    margin: 0 auto 2rem;
    font-family: system-ui, sans-serif;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  /* ── Buttons ────────────────────────────────── */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.65rem 1.4rem;
    border-radius: 6px;
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 160ms ease;
    font-family: inherit;
  }

  .btn-primary {
    background: #86efac;
    color: #0f172a;
  }

  .btn-primary:hover {
    background: #bbf7d0;
  }

  .btn-ghost {
    border: 1px solid rgba(255,255,255,0.2);
    color: #cbd5e1;
  }

  .btn-ghost:hover {
    border-color: rgba(255,255,255,0.4);
    color: #f1f5f9;
  }

  /* ── Sections ───────────────────────────────── */
  .section {
    margin-bottom: 4rem;
  }

  .section-title {
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: #64748b;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .prompt {
    color: #86efac;
  }

  /* ── Media frames ───────────────────────────── */
  .media-frame {
    border: 1px solid rgba(255,255,255,0.1);
    border-radius: 10px;
    overflow: hidden;
    background: #0d1117;
  }

  .media-img {
    width: 100%;
    height: auto;
    display: block;
  }

  .placeholder-block {
    height: 280px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.75rem;
    color: #475569;
    border: 2px dashed rgba(255,255,255,0.08);
    margin: 1rem;
    border-radius: 6px;
  }

  .placeholder-icon {
    font-size: 2rem;
    opacity: 0.5;
  }

  .placeholder-block code {
    font-size: 0.85rem;
    color: #64748b;
  }

  .media-caption {
    padding: 0.6rem 1rem;
    font-size: 0.78rem;
    color: #475569;
    border-top: 1px solid rgba(255,255,255,0.06);
    font-family: system-ui, sans-serif;
  }

  .media-caption code {
    color: #86efac;
  }

  /* ── Terminal block ─────────────────────────── */
  .terminal-block {
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid rgba(255,255,255,0.1);
    background: #090d13;
  }

  .terminal-bar {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1rem;
    background: #161b22;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
  }
  .dot.red    { background: #ff5f57; }
  .dot.yellow { background: #febc2e; }
  .dot.green  { background: #28c840; }

  .terminal-title {
    font-size: 0.75rem;
    color: #64748b;
    margin-left: auto;
    margin-right: auto;
  }

  .terminal-body {
    padding: 1.25rem 1.5rem;
    overflow-x: auto;
    line-height: 1.8;
    font-size: 0.88rem;
    margin: 0;
  }

  .c-comment { color: #475569; }
  .c-cmd     { color: #86efac; }
  .c-string  { color: #fde68a; }

  /* ── Feature list ───────────────────────────── */
  .feature-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    font-family: system-ui, sans-serif;
    font-size: 0.97rem;
    color: #cbd5e1;
    line-height: 1.6;
  }

  .feature-list li {
    display: flex;
    gap: 0.75rem;
  }

  .bullet {
    color: #86efac;
    flex-shrink: 0;
  }

  .feature-list code {
    font-family: 'JetBrains Mono', monospace;
    font-size: 0.85em;
    color: #86efac;
    background: rgba(134, 239, 172, 0.1);
    padding: 0.1em 0.35em;
    border-radius: 3px;
  }

  /* ── Stack grid ─────────────────────────────── */
  .stack-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
    gap: 1rem;
  }

  .stack-card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.1rem 1.25rem;
    border: 1px solid rgba(255,255,255,0.08);
    border-radius: 8px;
    background: rgba(255,255,255,0.03);
    transition: border-color 160ms ease, background 160ms ease;
  }

  .stack-card:hover {
    border-color: rgba(134, 239, 172, 0.3);
    background: rgba(134, 239, 172, 0.05);
  }

  .stack-icon { font-size: 1.3rem; }

  .stack-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #f1f5f9;
  }

  .stack-desc {
    font-size: 0.78rem;
    color: #64748b;
    font-family: system-ui, sans-serif;
  }

  /* ── CTA ────────────────────────────────────── */
  .cta-section {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    padding: 3.5rem 1rem;
    text-align: center;
    border-top: 1px solid rgba(255,255,255,0.08);
    margin-top: 2rem;
  }

  .cta-text {
    font-size: 1.1rem;
    color: #94a3b8;
    font-family: system-ui, sans-serif;
  }

  /* ── Responsive ─────────────────────────────── */
  @media (max-width: 600px) {
    .page { padding: 4rem 1rem 3rem; }
    .hero { padding-bottom: 2.5rem; margin-bottom: 2.5rem; }
  }
</style>
