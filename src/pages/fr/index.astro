---
import Layout from "../../layouts/Layout.astro";
import AppCard from "../../components/AppCard.astro";
import checkItLogo from "../../assets/applis/checkit.png";
import francoQuizLogo from "../../assets/applis/francoquiz.png";
import neonCuberLogo from "../../assets/applis/neoncuber.png";
import "../../styles/star-gradient.css";
---

<Layout title="Pierre Mollard" lang="fr">
  <div class="relative z-10 w-full max-w-3xl mx-auto px-6 flex-grow flex flex-col items-center justify-center gap-10 py-12">

    <div class="text-center w-full">
      <h1 class="text-2xl sm:text-3xl font-bold text-white tracking-tight mb-2">
        Pierre Mollard
      </h1>
      <p class="text-sm text-white/50 font-mono tracking-widest uppercase">
        Développeur · Bordeaux
      </p>
    </div>

    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-8 md:gap-12 w-full sm:min-h-[30rem]">
      <AppCard
        title="Check-It"
        description="Créez des objectifs quotidiens, puis suivez et atteignez-les."
        logo={checkItLogo.src}
        link="/check-it/check-it"
        colorLight="#E2E8F0"
        colorDark="#F9E79F"
      />
      <AppCard
        title="FrancoQuiz"
        description="Apprenez la géographie de la France à travers différents quiz."
        logo={francoQuizLogo.src}
        link="/francoquiz/francoquiz"
        colorLight="#E2E8F0"
        colorDark="#38BDF8"
      />
      <AppCard
        title="NeonCuber"
        description="Jeu inspiré du Rubik's Cube où il faut associer les couleurs identiques."
        logo={neonCuberLogo.src}
        link="/neoncuber/neoncuber"
        colorLight="#E2E8F0"
        colorDark="#0C0059"
      />
    </div>

  </div>
  <canvas id="starfield"></canvas>
</Layout>
