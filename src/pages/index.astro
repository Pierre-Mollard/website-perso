---
import Layout from "../layouts/Layout.astro";
import AppCard from "../components/AppCard.astro";
import checkItLogo from "../assets/applis/checkit.png";
import francoQuizLogo from "../assets/applis/francoquiz.png";
import neonCuberLogo from "../assets/applis/neoncuber.png";
import "../styles/star-gradient.css";
---

<Layout title="Pierre Mollard" lang="en">
  <div class="relative z-10 w-full max-w-3xl mx-auto px-6 sm:px-6 flex-grow flex flex-col items-center justify-center py-12">
    <div class="flex flex-col sm:flex-row justify-center items-center gap-4 sm:gap-8 md:gap-12 w-full">
			<AppCard
				title="Check-It"
				description="Create daily objective then track and follow them."
				logo={checkItLogo.src}
				link="/check-it/check-it"
				colorLight="#E2E8F0"
				colorDark="#F9E79F "
			/>
			<AppCard
				title="FrancoQuiz"
				description="Learn France geography through different quiz."
				logo={francoQuizLogo.src}
				link="/francoquiz/francoquiz"
				colorLight="#E2E8F0"
				colorDark="#38BDF8 "
			/>
			<AppCard
				title="NeonCuber"
				description="Rubik's Cube like game where you match colors."
				logo={neonCuberLogo.src}
				link="/neoncuber/neoncuber"
				colorLight="#E2E8F0"
				colorDark="#0C0059"
			/>
		</div>
  </div>
  <canvas id="starfield"></canvas>
</Layout>
